# Example environment variables for docker-compose (copy to .env and edit for local use)
# Supabase Postgres connection
SUPABASE_DATABASE_URL=postgres://<user>:<password>@<host>:5432/<dbname>
SUPABASE_DATABASE_USERNAME=<user>
SUPABASE_DATABASE_PASSWORD=<password>

# JWT secret (must be at least 32 characters) - change to a secure random string for production
JWT_SECRET=replace_with_a_secure_random_string_at_least_32_chars

# Optional: override backend port
# PORT=8080
