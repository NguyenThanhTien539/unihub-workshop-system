DB_URL=jdbc:postgresql://localhost:5432/unihub
DB_USERNAME=postgres
DB_PASSWORD=postgres

JWT_SECRET=replace_with_a_secure_random_string_at_least_32_chars
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
PORT=8080

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@unihub.local
APP_MAIL_QUEUE_ENABLED=false
APP_MAIL_QUEUE_STREAM=unihub-mail-jobs
APP_MAIL_QUEUE_CONSUMER_GROUP=unihub-mail-group
APP_MAIL_QUEUE_CONSUMER_NAME=unihub-backend
APP_MAIL_QUEUE_MAX_RETRIES=3
APP_MAIL_QUEUE_POLL_INTERVAL_MS=5000

APP_QR_ISSUER=unihub
APP_QR_TTL_MINUTES=10080
APP_QR_IMAGE_SIZE=320

APP_PAYMENT_PENDING_EXPIRATION_MINUTES=15
APP_PAYMENT_ZALOPAY_APP_ID=
APP_PAYMENT_ZALOPAY_KEY1=
APP_PAYMENT_ZALOPAY_KEY2=
APP_PAYMENT_ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
APP_PAYMENT_ZALOPAY_CONNECT_TIMEOUT_MS=3000
APP_PAYMENT_ZALOPAY_READ_TIMEOUT_MS=5000
APP_PAYMENT_ZALOPAY_CALLBACK_URL=http://localhost:8080/api/payments/zalopay/callback
APP_PAYMENT_ZALOPAY_FRONTEND_RETURN_URL=http://localhost:3000/payments/result
APP_PAYMENT_ZALOPAY_ENABLED=false
APP_PAYMENT_ZALOPAY_SANDBOX_MODE=true
APP_PAYMENT_EXPIRATION_CHECK_DELAY_MS=60000

APP_CSV_IMPORT_ENABLED=false
APP_CSV_IMPORT_INPUT_DIRECTORY=./data/import
APP_CSV_IMPORT_FILE_PATTERN=students-*.csv
APP_CSV_IMPORT_CRON=0 0 2 * * *
APP_CSV_IMPORT_TIMEZONE=Asia/Ho_Chi_Minh
APP_CSV_IMPORT_ENCODING=UTF-8
APP_CSV_IMPORT_DELIMITER=,
APP_CSV_IMPORT_BATCH_SIZE=500
APP_CSV_IMPORT_RECORD_MISSING_BATCH=false
